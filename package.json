{
	"name": "agent-thermos",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"packageManager": "bun@1.3.9",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"build": "bun run sync:skills && bun run sync:versions && bun run validate:generated",
		"changeset": "changeset",
		"dev": "bun test --watch",
		"format": "biome check --write .",
		"lint": "biome check .",
		"pack:check": "bun scripts/pack-check.ts",
		"release": "bun run test:ci && changeset publish",
		"sync:skills": "bun scripts/sync-skills.ts",
		"sync:versions": "bun scripts/sync-versions.ts",
		"test": "bun test",
		"test:ci": "bun run sync:skills && bun run sync:versions && bun run lint && bun run typecheck && bun run validate:generated && bun test && bun run pack:check",
		"typecheck": "tsc --noEmit",
		"validate:generated": "bun test packages/core/tests/generated.test.ts",
		"version": "changeset version"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.8",
		"@changesets/cli": "^2.29.7",
		"@types/node": "^24.10.1",
		"bun-types": "^1.3.3",
		"typescript": "^5.9.3"
	}
}
